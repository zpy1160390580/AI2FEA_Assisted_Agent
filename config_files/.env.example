# ============================================================================
# AI2FEA 辅助智能体 - 环境变量配置
# ============================================================================
#
# 本文件仅包含敏感信息（API Key）
# 其他所有配置参数请在 config.py 中修改
#
# 使用方法：
# 1. 复制本文件为 .env：cp .env.example .env
# 2. 编辑 .env 文件，填入您的 API Key
# 3. 其他参数（模型、阈值等）在 config.py 中配置
#
# ============================================================================

# 硅基流动平台 API Key（必填）
# 获取方式：https://cloud.siliconflow.cn/account/ak
SILICONFLOW_API_KEY=your_real_api_key_here

# ============================================================================
# 可选配置（如需修改默认值，请取消注释）
# ============================================================================

# API 基础 URL（默认：https://api.siliconflow.cn/v1）
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# Phoenix 可观测性平台端点（可选，用于追踪和评估）
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:6006

# ============================================================================
# 注意：
# - 模型选择、应力阈值等参数请在 config.py 中配置
# - .env 文件不应提交到 Git 仓库（已在 .gitignore 中）
# ============================================================================

